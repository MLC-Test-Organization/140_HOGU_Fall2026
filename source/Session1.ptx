  <worksheet>
    <title> Session #1 (Sections 1.1-1.2)</title>
    <p>
      Directions:
    </p>
    
    <paragraphs> <!--   %%%%%%%%%%%%%%%%   SECTION 1  %%%%%%%%%%%%%%%%%    -->
      <title>Getting Warmed Up and in the Right Mindset</title>

      <exercise workspace="1in"><!-- #1 -->
        <statement>
          <p>
            	Given the matrices below, determine if the following computations are possible. If the computations are possible, find the resulting matrix by hand (i.e., do the math without a calculator), then check your answer using your calculator. If the computation is not possible, state why. 
          </p>
          
            <m>
            A = \begin{bmatrix}
            2 &amp; -1 &amp; 4 \\
            0 &amp; 3 &amp; 5
            \end{bmatrix},
            \;
            B = \begin{bmatrix}
            1 &amp; 2 &amp; -3 \\
            4 &amp; -1 &amp; 0
            \end{bmatrix},
            \;
            E = \begin{bmatrix}
            1 &amp; 2 &amp; -3 \\
            6 &amp; 0 &amp; -4\\
            7 &amp; 18 &amp; 12
            \end{bmatrix},
            \;
            H = \begin{bmatrix}
            1 &amp; -2 \\
            0&amp; 4 \\
            -2 &amp; 3
            \end{bmatrix}
            </m>

           <ol marker="(a)">
              <li>
                <p>
                <m> A + 2B </m>
                </p>
              </li>
              <li>
                <p>
                 <m> 3A-H </m>
                </p>
              </li>
              <li>
                <p>
                  <m>4B-H^T </m>
                </p>
              </li>
              <li>
                <p>
                 <m> 2BH </m>
                </p>
              </li>
            </ol>
        </statement>
      </exercise>

      <exercise workspace="1in"><!-- #2 -->
        <statement>
          <p>
            	Find a matrix F such that the following matrix equation is true.
          </p>
          
            <m>
              \begin{bmatrix}
              1 &amp; 2 &amp; -3 \\
              6 &amp; 0 &amp; -4 \\
              7 &amp; 18 &amp; 12
              \end{bmatrix}
              - F =
              \begin{bmatrix}
              0 &amp; -10 &amp; 30 \\
              2 &amp; 5 &amp; -6 \\
              12 &amp; -3 &amp; 9
              \end{bmatrix}
              </m>

        </statement>
      </exercise>

      <exercise workspace="1in"><!-- #3 -->
        <statement>
          <p>
            Problem 3
          </p>
        </statement>
      </exercise>

    </paragraphs>

